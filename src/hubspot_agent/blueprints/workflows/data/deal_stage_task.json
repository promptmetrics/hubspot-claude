{
  "format_version": 1,
  "name": "deal_stage_task",
  "description": "Create a follow-up task when a deal moves to a specific stage.",
  "tags": [
    "deal",
    "task",
    "pipeline"
  ],
  "source": {
    "origin": "shipped"
  },
  "notes": [],
  "flags": [],
  "parameters": {
    "name": {
      "type": "string",
      "default": "Deal Stage Task",
      "description": "Workflow name"
    },
    "stage": {
      "type": "string",
      "default": "qualifiedtobuy",
      "description": "Deal stage internal ID to trigger on"
    },
    "task_title": {
      "type": "string",
      "default": "Follow up on deal stage change",
      "description": "Task title"
    },
    "due_days": {
      "type": "integer",
      "default": 1,
      "description": "Days until task is due"
    }
  },
  "spec": {
    "ui_path": "Settings > Automation > Workflows > Create workflow",
    "object_type": "Deal-based",
    "enrollment": {
      "type": "PROPERTY_BASED",
      "filter_branch": {
        "filterBranchType": "OR",
        "filterBranches": [
          {
            "filterBranchType": "AND",
            "filters": [
              {
                "filterType": "PROPERTY",
                "property": "dealstage",
                "operation": {
                  "operationType": "ENUMERATION",
                  "operator": "IS_ANY_OF",
                  "values": [
                    "{{param:stage}}"
                  ],
                  "includeObjectsWithNoValueSet": false
                }
              }
            ]
          }
        ]
      }
    },
    "actions": [
      {
        "step": 1,
        "ui_action": "Create task",
        "fields": {
          "Title": "{{param:task_title}}",
          "Due date": "{timestamp + {{param:due_days}}d}",
          "Assigned to": "{{deal.hubspot_owner_id}}",
          "Priority": "Medium",
          "Notes": "Deal moved to stage: {{param:stage}}"
        }
      }
    ],
    "prerequisites": [],
    "validation": [
      "Move a deal to the target stage",
      "Verify task is created"
    ]
  }
}
